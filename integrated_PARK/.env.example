# ══════════════════════════════════════════════════════════════
# SOHOBI 통합 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 저장하고 값을 채우십시오.
# ══════════════════════════════════════════════════════════════

# ── Azure OpenAI (핵심 — 전 에이전트 공통) ─────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_DEPLOYMENT_NAME=gpt-4o

# ── Azure OpenAI — 임베딩 (CHOI 법령 RAG) ──────────────────────
# 동일 리소스를 사용하면 위 값 그대로 사용 가능
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_EMBEDDING_API_VERSION=2024-02-01

# ── Azure AI Search (CHOI — 법령 벡터 검색) ────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX=legal-index

# ── 서울시 오픈 API (CHOI — 상권 분석) ─────────────────────────
# https://data.seoul.go.kr 에서 인증키 발급
SEOUL_API_KEY=<your-seoul-api-key>

# ── 로그 내보내기 (GET /api/v1/logs/export) ──────────────────────
# python3 -c "import secrets; print(secrets.token_urlsafe(32))" 로 생성
# Railway 환경변수에도 동일한 값 등록 필요
EXPORT_SECRET=<generate-with-secrets.token_urlsafe-32>
