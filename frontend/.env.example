# API base URL (required)
VITE_API_URL=http://localhost:8000

# Developer area password (SHA-256 hex hash of the desired password)
# Generate with:
#   node -e "const{createHash}=require('crypto'); console.log(createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
# If unset, /dev and /dev/logs will be inaccessible (auth always fails).
VITE_DEV_PASSWORD_HASH=
